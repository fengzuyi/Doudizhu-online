{
  "name": "@doudizhu/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run db:init",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "db:ensure": "node scripts/ensureDatabase.mjs",
    "db:init": "node scripts/devInit.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@doudizhu/shared": "file:../../packages/shared",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "livekit-server-sdk": "^2.15.4",
    "mysql2": "^3.22.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
