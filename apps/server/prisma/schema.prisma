generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BANNED
}

model User {
  id           String        @id @default(cuid())
  account      String        @unique @db.VarChar(64)
  nickname     String        @db.VarChar(32)
  passwordHash String        @db.VarChar(128)
  salt         String        @db.VarChar(64)
  status       UserStatus    @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lastLoginAt  DateTime?
  sessions     UserSession[]

  @@index([status])
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique @db.Char(64)
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([replacedAt])
}
